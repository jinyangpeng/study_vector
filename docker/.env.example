# ============================================================================
# study_vector — Docker 部署环境变量
# 拷贝为 .env 后按需修改：  cp .env.example .env
# ============================================================================

# ── 项目 ──
COMPOSE_PROJECT_NAME=study_vector
TAG=latest                          # 镜像 tag

# ── 应用环境 ──
APP_ENV=prod                        # dev / test / prod
LOG_LEVEL=INFO                      # DEBUG / INFO / WARNING / ERROR
LOG_JSON=true                       # 容器环境建议 JSON 日志

# ── Milvus 部署模式（核心开关）──
# milvus  = 内置模式：启动项目自带的 etcd+minio+milvus（开箱即用，推荐首次使用）
# （留空）= 外部模式：仅启动 api+frontend，连接你已部署的 Milvus（省资源）
#           外部模式时，务必把下方 MILVUS_HOST 改为外部 Milvus 的地址
COMPOSE_PROFILES=milvus

# ── Milvus 连接（API 连接 milvus 服务，容器内端口固定 19530）──
# 内置模式保持 milvus（compose service 名）；外部模式改为 IP/域名
MILVUS_HOST=milvus
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
MILVUS_DB_NAME=default
MILVUS_SECURE=false

# ── 宿主端口映射（仅改对外端口，不影响容器内通信）──
API_PORT=8000
FRONTEND_PORT=5173
MILVUS_HOST_PORT=19530              # Milvus gRPC
MILVUS_METRICS_PORT=9091            # Milvus metrics / healthz
MINIO_CONSOLE_PORT=9001             # MinIO 控制台

# ── MinIO 凭据（Milvus 对象存储后端）──
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── 镜像构建版本（一般无需修改）──
PYTHON_VERSION=3.11-slim
UV_VERSION=0.5.4
NODE_VERSION=20-alpine
NGINX_VERSION=1.27-alpine
